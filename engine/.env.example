# Kopieren nach engine/.env und ausfüllen — alles ist optional, die Engine
# degradiert sauber (ohne Claude: Kataloge/Templates; ohne SMTP: nur Entwürfe).

# Intelligenz (Kette: claude-CLI → API → Fallback)
# ANTHROPIC_API_KEY=sk-ant-…
# ENGINE_MODEL=claude-sonnet-5

# Versand (eigene Outreach-Domain empfohlen)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=outreach@agentur-domain.de
# SMTP_PASS=…
# SMTP_FROM="Agentur <outreach@agentur-domain.de>"

# Versand-Schalter (Rechts-Gates — siehe docs/06-baukasten-engine.md)
AUTO_SEND=false
AUTO_SEND_INTERNATIONAL=false

# Rankings (DataForSEO, pay-as-you-go)
# DATAFORSEO_LOGIN=…
# DATAFORSEO_PASSWORD=…

OUTREACH_MIN_SCORE=55
